@model List<AdminLibrary.Models.Book>

@{
    ViewData["Title"] = "Libros";
}

<div class="d-flex justify-content-between align-items-center page-header">
    <h3 class="fw-bold mb-0">📖 Catálogo de Libros</h3>

    <a asp-action="Create" asp-controller="Book" class="btn btn-primary">
        ➕ Agregar Libro
    </a>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <div style="font-size:4rem">📭</div>
        <h5 class="mt-3">No hay libros registrados</h5>

        <a asp-action="Create" class="btn btn-primary mt-2">
            Agregar el primero
        </a>
    </div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">

                <table class="table table-hover mb-0 align-middle">
                    <thead>
                        <tr>
                            <th>Título</th>
                            <th>Autor</th>
                            <th>Género</th>
                            <th>Descripción</th>
                            <th class="text-center">Stock</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var book in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@book.Title</td>
                                <td>@book.Author</td>
                                <td><span class="badge bg-secondary">@book.Genre</span></td>

                                <td class="text-muted small" style="max-width:200px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                    @book.Description
                                </td>

                                <td class="text-center">
                                    <span class="badge @(book.Stock > 0 ? "bg-success" : "bg-danger")">
                                        @book.Stock
                                    </span>
                                </td>

                                <td class="text-center">
                                    <a asp-action="Edit"
                                       asp-route-id="@book.Id"
                                       class="btn btn-sm btn-outline-primary">
                                        ✏️ Editar
                                    </a>

                                    <form asp-action="Delete"
                                          asp-controller="Book"
                                          asp-route-id="@book.Id"
                                          method="post"
                                          class="d-inline"
                                          onsubmit="return confirm('¿Eliminar este libro?');">

                                        @Html.AntiForgeryToken()

                                        <button type="submit"
                                                class="btn btn-sm btn-outline-danger">
                                            🗑️ Eliminar
                                        </button>

                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>

            </div>
        </div>
    </div>
}