@model AdminLibrary.Models.User
@{
    ViewData["Title"] = "Editar Usuario";
}

<div class="page-header">
    <h3 class="fw-bold mb-0">✏️ Editar Usuario</h3>
</div>

<div class="row">
    <div class="col-md-5">
        <div class="card">
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="id" type="hidden" />
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nombre de usuario</label>
                        <input asp-for="Username" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Email</label>
                        <input asp-for="Email" type="email" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nueva contraseña <span class="text-muted small">(dejar vacío para no cambiar)</span></label>
                        <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" />
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Rol</label>
                        <select asp-for="Role" class="form-select">
                            <option value="User">👤 Usuario</option>
                            <option value="Admin">🔑 Administrador</option>
                        </select>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">💾 Guardar cambios</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
