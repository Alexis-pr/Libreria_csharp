@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Iniciar Sesión — Librería</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); min-height: 100vh; display:flex; align-items:center; }
        .card { border:none; border-radius:16px; box-shadow: 0 20px 60px rgba(0,0,0,.4); }
        .brand-icon { font-size: 3rem; }
    </style>
</head>
<body>
<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-4 col-sm-8">
            <div class="card p-4">
                <div class="text-center mb-4">
                    <div class="brand-icon">📚</div>
                    <h4 class="fw-bold mt-2">AdminLibrary</h4>
                    <p class="text-muted small">Sistema de Gestión de Librería</p>
                </div>

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">✅ @TempData["Success"]</div>
                }

                <form method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Correo electrónico</label>
                        <input type="email" name="Email" class="form-control" placeholder="correo@ejemplo.com" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Contraseña</label>
                        <input type="password" name="Password" class="form-control" placeholder="••••••••" required />
                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger py-2">⚠️ @ViewBag.Error</div>
                    }

                    <button type="submit" class="btn btn-primary w-100 py-2 fw-bold">Iniciar Sesión</button>
                </form>

                <div class="text-center mt-3">
                    <small class="text-muted">¿No tienes cuenta?
                        <a asp-controller="Auth" asp-action="Register" class="text-decoration-none fw-semibold">Regístrate</a>
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
